# k3s Configuration
# Managed by Ansible

# Network
bind-address: 0.0.0.0
node-ip: {{ k3s_node_ip }}
node-external-ip: {{ k3s_node_ip }}
https-listen-port: 6443

# Cluster — single-node uses k3s's default SQLite/kine datastore (no
# `cluster-init`, which would force the heavier embedded etcd: etcd
# holds the keyspace in RAM + runs its own compaction/snapshotting,
# ~150-300Mi more RSS for zero benefit on one node). The whole cluster
# is reproducible via Pulumi+Ansible and app data is hostPath on the
# Mac, so etcd's auto-snapshots were redundant here. If you ever go
# multi-node HA, re-add `cluster-init: true`.
token: {{ k3s_cluster_token }}

# Storage
data-dir: {{ k3s_data_dir }}

# Kubeconfig
write-kubeconfig-mode: "0644"
write-kubeconfig: /etc/rancher/k3s/k3s.yaml

# TLS SANs
tls-san:
  - {{ ansible_host }}
  - {{ k3s_node_ip }}
  - localhost
  - 127.0.0.1
{% if k3s_tailscale_ip | default('') != '' %}
  - {{ k3s_tailscale_ip }}
{% endif %}
{% for san in k3s_tls_san %}
  - {{ san }}
{% endfor %}

# Disabled Components
{% if k3s_disable_components %}
disable:
{% for component in k3s_disable_components %}
  - {{ component }}
{% endfor %}
{% endif %}

# Kubelet
# resolv-conf must point at the uplink resolv.conf (with real upstream
# DNS servers), not /etc/resolv.conf which on systemd-resolved hosts is
# the 127.0.0.53 stub. Without this, kubelet hands the stub to pods
# that inherit host DNS (CoreDNS uses dnsPolicy: Default), CoreDNS
# forwards back into itself, and the loop plugin fatals on startup.
kubelet-arg:
  - "max-pods=250"
  - "resolv-conf=/run/systemd/resolve/resolv.conf"

# API Server
kube-apiserver-arg:
  - "enable-admission-plugins=NodeRestriction,ResourceQuota"
