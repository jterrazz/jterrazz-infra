# Docker Registry - Private container registry
# Accessible via Tailscale VPN with TLS
# Credentials injected by Ansible from Pulumi
# Self-contained: includes Deployment, Service, IngressRoute, Certificate

---
apiVersion: v1
kind: Secret
metadata:
  name: registry-auth
  namespace: platform-registry
type: Opaque
stringData:
  htpasswd: "{{ registry_htpasswd }}"

---
# Bind the registry to a hostPath PV at /var/lib/k8s-data/registry/ —
# same pattern as every other platform service. Critical on OrbStack:
# without this the PVC binds to the default local-path provisioner
# under /var/lib/rancher/k3s/storage/... which gets wiped on
# `pulumi destroy && pulumi up` (registry blobs lost). The hostPath
# version follows the Mac-side symlink for free.
apiVersion: v1
kind: PersistentVolume
metadata:
  name: registry-data
  labels:
    app: registry
spec:
  capacity:
    storage: 10Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: manual
  hostPath:
    path: /var/lib/k8s-data/registry
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - {{ inventory_hostname }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: registry-data
  namespace: platform-registry
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 10Gi
  storageClassName: manual
  volumeName: registry-data

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: registry
  namespace: platform-registry
  labels:
    app: registry
spec:
  replicas: 1
  selector:
    matchLabels:
      app: registry
  template:
    metadata:
      labels:
        app: registry
    spec:
      containers:
        - name: registry
          image: registry:2
          ports:
            - containerPort: 5000
          env:
            - name: REGISTRY_AUTH
              value: "htpasswd"
            - name: REGISTRY_AUTH_HTPASSWD_REALM
              value: "Registry"
            - name: REGISTRY_AUTH_HTPASSWD_PATH
              value: "/auth/htpasswd"
            - name: REGISTRY_STORAGE_DELETE_ENABLED
              value: "true"
          volumeMounts:
            - name: data
              mountPath: /var/lib/registry
            - name: auth
              mountPath: /auth
              readOnly: true
          resources:
            requests:
              cpu: 10m
              memory: 48Mi
            limits:
              memory: 64Mi
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: registry-data
        - name: auth
          secret:
            secretName: registry-auth

---
apiVersion: v1
kind: Service
metadata:
  name: registry
  namespace: platform-registry
spec:
  type: ClusterIP
  ports:
    - port: 5000
      targetPort: 5000
  selector:
    app: registry

---
# IngressRoute - Private access via Tailscale
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: registry
  namespace: platform-registry
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`registry.jterrazz.com`)
      kind: Rule
      middlewares:
        - name: private-access
          namespace: platform-networking
      services:
        - name: registry
          port: 5000
  tls:
    secretName: registry-tls

---
# TLS Certificate
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: registry-tls
  namespace: platform-registry
spec:
  secretName: registry-tls
  issuerRef:
    name: letsencrypt-production
    kind: ClusterIssuer
  dnsNames:
    - registry.jterrazz.com
