---
# PVC name must match Loki StatefulSet volumeClaimTemplate: storage-<release>-0
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: storage-loki-0
  namespace: platform-telemetry
spec:
  accessModes:
    - ReadWriteOnce
