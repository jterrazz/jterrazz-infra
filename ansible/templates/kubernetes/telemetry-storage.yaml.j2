---
# Telemetry hostPath PVs and PVCs.
#
# Rendered by Ansible at deploy-time so nodeAffinity binds to whichever
# k8s node we're actually running on (= `jterrazz-infrastructure` today). Single-
# node k3s — the affinity is more of a safety belt than a scheduling
# lever, but having it set correctly avoids "1 node(s) didn't match
# PersistentVolume's node affinity" scheduling failures when the
# template runs against a renamed node.

# Grafana data (dashboards, config)
apiVersion: v1
kind: PersistentVolume
metadata:
  name: grafana-data
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: manual
  hostPath:
    path: /var/lib/k8s-data/grafana
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - {{ inventory_hostname }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: grafana-data
  namespace: platform-telemetry
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: manual
  resources:
    requests:
      storage: 1Gi
  volumeName: grafana-data
---
# Loki data (logs) — 90d query window (see loki/helm.yaml)
apiVersion: v1
kind: PersistentVolume
metadata:
  name: loki-data
spec:
  capacity:
    storage: 20Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: manual
  hostPath:
    path: /var/lib/k8s-data/loki
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - {{ inventory_hostname }}
---
# PVC name must match Loki StatefulSet volumeClaimTemplate: storage-<release>-0
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: storage-loki-0
  namespace: platform-telemetry
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: manual
  resources:
    requests:
      storage: 20Gi
  volumeName: loki-data
