{
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 50, "title": "CPU", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }],
      "title": "CPU Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }, "unit": "percent", "min": 0, "max": 100 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "user" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "system" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "iowait" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "idle" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 1 },
      "id": 2,
      "targets": [
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\"}[5m])) * 100", "legendFormat": "user", "refId": "A" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\"}[5m])) * 100", "legendFormat": "system", "refId": "B" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100", "legendFormat": "iowait", "refId": "C" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100", "legendFormat": "idle", "refId": "D" }
      ],
      "title": "CPU Breakdown",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "unit": "short" } },
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 1 },
      "id": 3,
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15", "legendFormat": "15m", "refId": "C" },
        { "expr": "count(node_cpu_seconds_total{mode=\"idle\"})", "legendFormat": "CPU cores", "refId": "D" }
      ],
      "title": "Load Average",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }, "id": 51, "title": "Memory", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 8 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "refId": "A" }],
      "title": "Memory Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }, "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Buffers" }, "properties": [{ "id": "color", "value": { "fixedColor": "light-yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Cached" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Available" }, "properties": [{ "id": "color", "value": { "fixedColor": "super-light-green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 8 },
      "id": 5,
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes - node_memory_Buffers_bytes - node_memory_Cached_bytes", "legendFormat": "Used", "refId": "A" },
        { "expr": "node_memory_Buffers_bytes", "legendFormat": "Buffers", "refId": "B" },
        { "expr": "node_memory_Cached_bytes", "legendFormat": "Cached", "refId": "C" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "D" }
      ],
      "title": "Memory Breakdown",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "unit": "bytes" } },
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 8 },
      "id": 6,
      "targets": [
        { "expr": "node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes", "legendFormat": "Swap used", "refId": "A" },
        { "expr": "node_memory_SwapTotal_bytes", "legendFormat": "Swap total", "refId": "B" }
      ],
      "title": "Swap Usage",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 52, "title": "Disk", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 15 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "refId": "A" }],
      "title": "Disk Usage (/)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 }, "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Available" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 15 },
      "id": 8,
      "targets": [
        { "expr": "node_filesystem_size_bytes{mountpoint=\"/\"} - node_filesystem_avail_bytes{mountpoint=\"/\"}", "legendFormat": "Used", "refId": "A" },
        { "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}", "legendFormat": "Available", "refId": "B" }
      ],
      "title": "Disk Space (/)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "unit": "Bps" } },
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 15 },
      "id": 9,
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "{{device}} read", "refId": "A" },
        { "expr": "-rate(node_disk_written_bytes_total[5m])", "legendFormat": "{{device}} write", "refId": "B" }
      ],
      "title": "Disk I/O",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }, "id": 53, "title": "Network", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "unit": "bps" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "id": 10,
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device=~\"eth.*|enp.*\"}[5m]) * 8", "legendFormat": "{{device}} rx", "refId": "A" },
        { "expr": "-rate(node_network_transmit_bytes_total{device=~\"eth.*|enp.*\"}[5m]) * 8", "legendFormat": "{{device}} tx", "refId": "B" }
      ],
      "title": "Network Bandwidth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "unit": "pps" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "id": 11,
      "targets": [
        { "expr": "rate(node_network_receive_packets_total{device=~\"eth.*|enp.*\"}[5m])", "legendFormat": "{{device}} rx", "refId": "A" },
        { "expr": "-rate(node_network_transmit_packets_total{device=~\"eth.*|enp.*\"}[5m])", "legendFormat": "{{device}} tx", "refId": "B" }
      ],
      "title": "Network Packets",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }, "id": 54, "title": "System", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] }, "unit": "dtdurations" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 30 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "time() - node_boot_time_seconds", "refId": "A" }],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 30 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(node_cpu_seconds_total{mode=\"idle\"})", "refId": "A" }],
      "title": "CPU Cores",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }, "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 30 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "node_memory_MemTotal_bytes", "refId": "A" }],
      "title": "Total RAM",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }, "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 30 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "node_filesystem_size_bytes{mountpoint=\"/\"}", "refId": "A" }],
      "title": "Total Disk",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["infrastructure", "vps"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "VPS - Server Overview",
  "uid": "infra-vps-overview"
}
