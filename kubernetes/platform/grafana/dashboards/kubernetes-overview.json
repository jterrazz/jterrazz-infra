{
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 50, "title": "Cluster Overview", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background_solid", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_pod_info)", "refId": "A" }],
      "title": "Total Pods",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background_solid", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=~\"Failed|Unknown\"}) or vector(0)", "refId": "A" }],
      "title": "Failed Pods",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background_solid", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_deployment_spec_replicas)", "refId": "A" }],
      "title": "Deployments",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background_solid", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_namespace_labels)", "refId": "A" }],
      "title": "Namespaces",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background_solid", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_container_status_restarts_total > 5) or vector(0)", "refId": "A" }],
      "title": "Containers w/ >5 Restarts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background_solid", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_container_status_waiting_reason{reason=~\"CrashLoopBackOff|ErrImagePull|ImagePullBackOff\"}) or vector(0)", "refId": "A" }],
      "title": "Unhealthy Containers",
      "type": "stat"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 51, "title": "Resource Usage", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "targets": [{ "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m]))", "legendFormat": "{{namespace}}", "refId": "A" }],
      "title": "CPU Usage by Namespace",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }, "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "targets": [{ "expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\", container!=\"POD\"})", "legendFormat": "{{namespace}}", "refId": "A" }],
      "title": "Memory Usage by Namespace",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] }, "color": { "mode": "thresholds" }, "min": 0, "max": 100 } },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m])) / sum(kube_pod_container_resource_requests{resource=\"cpu\"}) * 100", "refId": "A" }],
      "title": "CPU Requests Utilization",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] }, "color": { "mode": "thresholds" }, "min": 0, "max": 100 } },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 14 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}) / sum(kube_pod_container_resource_requests{resource=\"memory\"}) * 100", "refId": "A" }],
      "title": "Memory Requests Utilization",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "unit": "Bps" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "id": 11,
      "targets": [
        { "expr": "sum by (namespace) (rate(container_network_receive_bytes_total{namespace!=\"\"}[5m]))", "legendFormat": "{{namespace}} rx", "refId": "A" },
        { "expr": "-sum by (namespace) (rate(container_network_transmit_bytes_total{namespace!=\"\"}[5m]))", "legendFormat": "{{namespace}} tx", "refId": "B" }
      ],
      "title": "Network I/O by Namespace",
      "type": "timeseries"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }, "id": 52, "title": "Pods & Deployments", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Running" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Succeeded" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 12,
      "targets": [
        { "expr": "sum(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running", "refId": "A" },
        { "expr": "sum(kube_pod_status_phase{phase=\"Pending\"})", "legendFormat": "Pending", "refId": "B" },
        { "expr": "sum(kube_pod_status_phase{phase=\"Failed\"})", "legendFormat": "Failed", "refId": "C" },
        { "expr": "sum(kube_pod_status_phase{phase=\"Succeeded\"})", "legendFormat": "Succeeded", "refId": "D" }
      ],
      "title": "Pod Status Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 13,
      "targets": [{ "expr": "sum by (namespace, container) (increase(kube_pod_container_status_restarts_total[1h])) > 0", "legendFormat": "{{namespace}}/{{container}}", "refId": "A" }],
      "title": "Container Restarts (last 1h)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "displayName", "value": "Desired" }] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "displayName", "value": "Available" }] },
          { "matcher": { "id": "byName", "options": "Value #C" }, "properties": [{ "id": "displayName", "value": "Unavailable" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "id": 14,
      "options": { "sortBy": [{ "desc": true, "displayName": "Unavailable" }] },
      "targets": [
        { "expr": "kube_deployment_spec_replicas", "format": "table", "instant": true, "refId": "A" },
        { "expr": "kube_deployment_status_replicas_available", "format": "table", "instant": true, "refId": "B" },
        { "expr": "kube_deployment_status_replicas_unavailable", "format": "table", "instant": true, "refId": "C" }
      ],
      "title": "Deployment Replica Status",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "namespace|deployment|Value" } } },
        { "id": "organize", "options": { "renameByName": { "namespace": "Namespace", "deployment": "Deployment" } } }
      ],
      "type": "table"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 }, "id": 53, "title": "Top Consumers", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "id": 15,
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "topk(10, sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m])))", "legendFormat": "{{namespace}}/{{pod}}", "refId": "A" }],
      "title": "Top 10 CPU Consumers",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "id": 16,
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "topk(10, sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}))", "legendFormat": "{{namespace}}/{{pod}}", "refId": "A" }],
      "title": "Top 10 Memory Consumers",
      "type": "bargauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["infrastructure", "kubernetes"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Kubernetes - Cluster Overview",
  "uid": "infra-k8s-overview"
}
